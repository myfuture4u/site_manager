generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String           @id @default(cuid())
  email       String           @unique
  name        String
  password    String
  role        String           @default("OTHER")
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  auditLogs   AuditLog[]
  comments    Comment[]
  sites         Site[]           @relation("CreatedBy")
  attachments   SiteAttachment[]
  notifications Notification[]
}

model Site {
  id               String           @id @default(cuid())
  name             String
  address          String
  street           String?
  ward             String?
  district         String?
  city             String
  siteType         String
  description      String?
  rentPrice        Float?
  rentUnit         String?
  rentType         String?
  floorArea        Float?
  frontage         Float?
  floors           Int?
  mapsLink         String?
  status           String           @default("NEW")
  
  // Visibility and Workflow Fields
  isSubmitted      Boolean          @default(false)
  visibleToRoles   String           @default("[]") // Store as JSON string array ["BOD", "BRAND_TEAM"]
  visibleToUsers   String           @default("[]") // Store as JSON string array of user IDs
  brand            String?          // To store the brand this site belongs to
  
  createdById      String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  auditLogs        AuditLog[]
  comments         Comment[]
  createdBy        User             @relation("CreatedBy", fields: [createdById], references: [id])
  attachments      SiteAttachment[]

  @@index([city])
  @@index([status])
  @@index([siteType])
}

model SiteAttachment {
  id           String   @id @default(cuid())
  siteId       String
  fileName     String
  fileUrl      String
  fileType     String
  fileSize     Int?
  uploadedById String
  createdAt    DateTime @default(now())
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
}

model Comment {
  id        String   @id @default(cuid())
  siteId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
}

model AuditLog {
  id           String   @id @default(cuid())
  siteId       String
  userId       String
  action       String
  fieldChanged String?
  oldValue     String?
  newValue     String?
  description  String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
}

model MasterData {
  id          String   @id @default(cuid())
  type        String   // Tỉnh/Thành phố, Quận/Huyện, Phường/Xã, Loại hình, ...
  value       String   // Giá trị
  parentValue String?  // Optional: dành cho Phường/Xã thì parentValue có thể là mã/tên Thành phố
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([type])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  siteId      String?
  title       String
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}
